{
  "compilerOptions": {
    "target": "ES2022",

    "module": "ESNext",
    "moduleResolution": "Bundler",

    "jsx": "react",
    
    "strict": true,

    "skipLibCheck": true,

    "esModuleInterop": true,

    "resolveJsonModule": true,

    "forceConsistentCasingInFileNames": true,

    "types": ["node"],

    "lib": ["ES2022"],

    "noEmit": true
  },

  "include": ["src"]
}